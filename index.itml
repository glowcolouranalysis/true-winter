<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>True Winter</title>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400&family=Jost:wght@300;400&display=swap" rel="stylesheet">

<style>
body {
  margin:0;
  font-family:'Jost',sans-serif;
  background:#F4F6FB;
}

/* HEADER */
.header {
  text-align:center;
  padding:110px 20px 50px;
}

.brand {
  letter-spacing:5px;
  font-size:12px;
  color:#7C8396;
  margin-bottom:18px;
}

h1 {
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(90px, 15vw, 150px);
  font-weight:300;
  margin:0;
  line-height:1.05;

  background:linear-gradient(135deg,#4A5CFF,#B94DB5,#D6456E);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

.header-sub {
  margin-top:22px;
  font-size:16px;
  color:#6B7280;
}

.header-divider {
  width:70px;
  height:2px;
  background:#C9CEDA;
  margin:30px auto 0;
}

/* GRID — FULL WIDTH (FIXED) */
.grid {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:14px;

  width:100%;
  padding:0 14px 60px;
}

/* CARD */
.card {
  background:white;
  border-radius:14px;
  overflow:hidden;
  box-shadow:0 8px 20px rgba(0,0,0,0.06);
}

/* COLOUR */
.color {
  height:100px;
}

/* TEXT */
.meta {
  padding:12px;
}

.meta strong {
  display:block;
  font-size:12px;
  letter-spacing:0.8px;
}

.meta span {
  font-size:12px;
  color:#6B7280;
}

/* FULLSCREEN */
.fs {
  position:fixed;
  inset:0;
  display:none;
  flex-direction:column;
}

.fs.active {
  display:flex;
}

.fs-colour {
  flex:1;
}

.fs-bottom {
  background:white;
  padding:22px;
  border-top-left-radius:24px;
  border-top-right-radius:24px;
}

.fs-name {
  font-family:'Cormorant Garamond',serif;
  font-size:28px;
}

.fs-hex {
  font-size:15px;
  color:#6B7280;
}
</style>
</head>

<body>

<div class="header">
  <div class="brand">GLOW COLOUR ANALYSIS</div>
  <h1>True Winter</h1>
  <div class="header-sub">Click any swatch to explore · Tap again to close</div>
  <div class="header-divider"></div>
</div>

<div class="grid" id="grid"></div>

<div class="fs" id="fs">
  <div class="fs-colour" id="fsColour"></div>
  <div class="fs-bottom">
    <div class="fs-name" id="fsName"></div>
    <div class="fs-hex" id="fsHex"></div>
  </div>
</div>

<script>
const colours = [
  {name:"Winter Red", hex:"#B50038"},
  {name:"Electric Blue", hex:"#0033FF"},
  {name:"Hot Magenta", hex:"#CC0099"},
  {name:"Royal Blue", hex:"#1B3A8F"},
  {name:"Cobalt", hex:"#0047CC"},
  {name:"Fuchsia", hex:"#BF0080"}
];

const grid = document.getElementById("grid");

grid.innerHTML = colours.map((c,i)=>`
  <div class="card" onclick="openFs(${i})">
    <div class="color" style="background:${c.hex}"></div>
    <div class="meta">
      <strong>${c.name}</strong>
      <span>${c.hex}</span>
    </div>
  </div>
`).join("");

function openFs(i){
  const c = colours[i];
  document.getElementById("fs").classList.add("active");
  document.getElementById("fsColour").style.background = c.hex;
  document.getElementById("fsName").innerText = c.name;
  document.getElementById("fsHex").innerText = c.hex;
}

document.getElementById("fs").onclick = () => {
  document.getElementById("fs").classList.remove("active");
};
</script>

</body>
</html>
